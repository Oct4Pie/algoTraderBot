#!/usr/bin/env bash
# Pre-commit hook: run the full unit-test suite; block the commit if it fails.
#
# Enable once per clone:   git config core.hooksPath .githooks
# Skip for one commit:     git commit --no-verify
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

# Pick an interpreter that actually has pytest installed.
PY=""
for cand in python3.11 python3 python; do
  if command -v "$cand" >/dev/null 2>&1 && "$cand" -m pytest --version >/dev/null 2>&1; then
    PY="$cand"; break
  fi
done
if [ -z "$PY" ]; then
  echo "✗ pre-commit: pytest not found on any python — run 'pip install -r requirements.txt'"
  exit 1
fi

# futures_foundation may be a local sibling checkout rather than pip-installed.
if ! "$PY" -c "import futures_foundation" >/dev/null 2>&1; then
  FFM="$(cd "$ROOT/.." && pwd)/Futures-Foundation-Model"
  if [ -d "$FFM" ]; then
    export PYTHONPATH="$FFM${PYTHONPATH:+:$PYTHONPATH}"
  fi
fi

echo "▶ pre-commit: running unit tests…"
if ! "$PY" -m pytest tests/ -q; then
  echo "✗ tests failed — commit aborted (use 'git commit --no-verify' to skip)"
  exit 1
fi
echo "✓ tests passed"
